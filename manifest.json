{
  "manifest_version": 3,
  "name": "AI Helper - 网页智能助手",
  "version": "1.0.0",
  "description": "选中文本内容直接发起API调用，获取智能结果展示",
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage",
    "sidePanel",
    "scripting",
    "bookmarks",
    "history",
    "downloads",
    "notifications",
    "tabs",
    "cookies",
    "alarms",
    "pageCapture",
    "debugger",
    "browsingData",
    "tabGroups"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["libs/qrcode.min.js", "libs/marked.min.js", "src/content/index.js"],
      "css": ["styles/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "action": {
    "default_title": "AI Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}